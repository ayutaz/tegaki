{
  "name": "tegaki",
  "version": "0.1.0",
  "type": "module",
  "description": "React component for rendering animated handwriting from any font",
  "keywords": [
    "handwriting",
    "animation",
    "svg",
    "react",
    "font",
    "calligraphy",
    "stroke-order",
    "text-animation",
    "writing-animation"
  ],
  "homepage": "https://github.com/KurtGokhan/tegaki#readme",
  "bugs": {
    "url": "https://github.com/KurtGokhan/tegaki/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/KurtGokhan/tegaki.git",
    "directory": "packages/renderer"
  },
  "license": "MIT",
  "author": {
    "name": "Gokhan Kurt",
    "email": "krtgkn@gmail.com",
    "url": "https://gkurt.com"
  },
  "exports": {
    ".": {
      "tegaki@dev": "./src/index.ts",
      "source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsdown src/index.ts --dts --sourcemap",
    "prepack": "bun run build && bun ../../scripts/prepareForRelease.ts"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  }
}
